generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String?
  name          String?
  bio           String?
  profilePic    String?  @db.Text
  role          String   @default("user") // "user" | "admin"
  banned        Boolean  @default(false)
  verified      Boolean  @default(false)
  status        String?
  affiliateRate Int      @default(20)
  // Payment method untuk menerima pembayaran
  bankName      String?
  bankAccount   String?
  bankHolder    String?
  qrisImage     String?  @db.Text  // base64 QRIS image
  // WhatsApp Responder
  waNumber      String?
  waMessage     String?  // auto-reply template after purchase
  // Gift system
  giftBalance   Int      @default(0)   // IDR kredit gift pembaca (beli di platform)
  giftRedeemed  Int      @default(0)   // total gift earnings kreator yang sudah dicairkan
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  posts           Post[]
  likes           Like[]
  savedPosts      SavedPost[]
  purchases       Purchase[]
  filePurchases   FilePurchase[]
  bundlePurchases BundlePurchase[]
  discounts       Discount[]
  bundles         Bundle[]
  followers       Follow[]        @relation("following")
  following       Follow[]        @relation("follower")
  images          Image[]
  sessions        Session[]
  accounts        Account[]
  withdrawals     Withdrawal[]
  comments        Comment[]
  ratings         Rating[]
  sentGifts       SentGift[]      @relation("giftSender")
  receivedGifts   SentGift[]      @relation("giftReceiver")
  giftRedemptions GiftRedemption[]
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?
  type        String    // "markdown" | "html"
  content     String    @db.Text
  category    String?
  tags        String[]
  published   Boolean   @default(false)
  isPrivate   Boolean   @default(false)  // private note: visible to author only, not in feed
  publishedAt DateTime?
  viewCount   Int       @default(0)
  likeCount   Int       @default(0)
  coverImage  String?   @db.Text
  isPremium        Boolean   @default(false)
  price            Int?      // IDR
  discount         Int?      // % off, e.g. 20 = 20% off
  affiliateEnabled Boolean   @default(false)
  affiliateRate    Int       @default(20)  // % commission for affiliates
  createdAt        DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  likes       Like[]
  savedPosts  SavedPost[]
  views       PostView[]
  files       PostFile[]
  purchases   Purchase[]
  discounts   Discount[]
  bundleItems BundleItem[]
  comments    Comment[]
  ratings     Rating[]
  sentGifts   SentGift[]   @relation("postSentGifts")
}

model PostFile {
  id        String    @id @default(cuid())
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  name      String
  mimeType  String    // "url/link" for external links
  size      Int       @default(0)
  data      String?   @db.Text  // base64; null for URL attachments
  url       String?             // external URL for link-type attachments
  isFree    Boolean   @default(true)
  price     Int?      // IDR — file can be sold separately
  discount  Int?      // % off on file price
  createdAt DateTime  @default(now())

  filePurchases FilePurchase[]
  bundleItems   BundleItem[]
}

model Purchase {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  post       Post     @relation(fields: [postId], references: [id])
  postId     String
  amount     Int
  serviceFee Int      @default(0)
  status     String   @default("pending")
  orderId    String   @unique
  refCode    String?
  payerName  String?
  payerWa    String?
  createdAt  DateTime @default(now())

  @@unique([userId, postId])
}

model FilePurchase {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  file       PostFile @relation(fields: [fileId], references: [id])
  fileId     String
  amount     Int
  status     String   @default("pending")
  orderId    String   @unique
  payerName  String?
  payerWa    String?
  createdAt  DateTime @default(now())

  @@unique([userId, fileId])
}

model Bundle {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?
  price       Int
  discount    Int?      // % off
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String

  items     BundleItem[]
  purchases BundlePurchase[]
}

model BundleItem {
  id       String    @id @default(cuid())
  bundle   Bundle    @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  bundleId String
  post     Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId   String?
  file     PostFile? @relation(fields: [fileId], references: [id], onDelete: Cascade)
  fileId   String?
  order    Int       @default(0)
}

model BundlePurchase {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  bundle    Bundle   @relation(fields: [bundleId], references: [id])
  bundleId  String
  amount    Int
  status    String   @default("pending")
  orderId   String   @unique
  payerName String?
  payerWa   String?
  createdAt DateTime @default(now())

  @@unique([userId, bundleId])
}

model Discount {
  id         String    @id @default(cuid())
  author     User      @relation(fields: [authorId], references: [id])
  authorId   String
  post       Post?     @relation(fields: [postId], references: [id])
  postId     String?   // null = valid for all posts by this author
  code       String    @unique
  type       String    // "percent" | "fixed"
  value      Int       // percent (1-100) or IDR amount
  maxUses    Int?      // null = unlimited
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
}

model Image {
  id         String   @id @default(cuid())
  data       String   @db.Text
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())
  uploader   User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  uploaderId String
}

model Follow {
  id          String   @id @default(cuid())
  follower    User     @relation("follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  followerId  String
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Like {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model PostView {
  id       String   @id @default(cuid())
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId   String
  deviceId String
  viewedAt DateTime @default(now())

  @@unique([postId, deviceId])
}

model SavedPost {
  id      String   @id @default(cuid())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId  String
  savedAt DateTime @default(now())

  @@unique([userId, postId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Withdrawal {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  amount      Int
  status      String   @default("pending") // pending | approved | paid | rejected
  bankName    String
  bankAccount String
  bankHolder  String
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
}

model Rating {
  id        String   @id @default(cuid())
  value     Int      // 1-5
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  @@unique([userId, postId])
}

model GiftItem {
  id       String  @id @default(cuid())
  emoji    String
  name     String
  price    Int     // IDR
  isActive Boolean @default(true)
  order    Int     @default(0)

  sentGifts SentGift[]
}

model SentGift {
  id        String   @id @default(cuid())
  amount    Int      // IDR paid
  message   String?
  createdAt DateTime @default(now())

  sender     User     @relation("giftSender",   fields: [senderId],    references: [id], onDelete: Cascade)
  senderId   String
  receiver   User     @relation("giftReceiver", fields: [receiverId],  references: [id], onDelete: Cascade)
  receiverId String
  post       Post     @relation("postSentGifts", fields: [postId],     references: [id], onDelete: Cascade)
  postId     String
  giftItem   GiftItem @relation(fields: [giftItemId], references: [id])
  giftItemId String
}

model GiftRedemption {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  amount    Int      // IDR yang dicairkan
  status    String   @default("pending") // pending | approved | paid | rejected
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
