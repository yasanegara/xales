generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String?
  name          String?
  bio           String?
  profilePic    String?  @db.Text
  status        String?
  affiliateRate Int      @default(20)
  // Rekening (withdrawal)
  bankName      String?
  bankAccount   String?
  bankHolder    String?
  // WhatsApp Responder
  waNumber      String?
  waMessage     String?  // auto-reply template after purchase
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  posts         Post[]
  likes         Like[]
  savedPosts    SavedPost[]
  purchases     Purchase[]
  discounts     Discount[]
  followers     Follow[]  @relation("following")
  following     Follow[]  @relation("follower")
  sessions      Session[]
  accounts      Account[]
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?
  type        String    // "markdown" | "html"
  content     String    @db.Text
  category    String?
  tags        String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  viewCount   Int       @default(0)
  likeCount   Int       @default(0)
  coverImage  String?   @db.Text
  isPremium   Boolean   @default(false)
  price       Int?      // IDR, e.g. 25000 = Rp 25.000
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  likes      Like[]
  savedPosts SavedPost[]
  views      PostView[]
  files      PostFile[]
  purchases  Purchase[]
  discounts  Discount[]
}

model PostFile {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  name      String
  mimeType  String
  size      Int      // bytes
  data      String   @db.Text // base64
  isFree    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Purchase {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  post      Post     @relation(fields: [postId], references: [id])
  postId    String
  amount    Int      // IDR actually paid (after discount)
  status    String   @default("pending") // pending | paid | failed
  orderId   String   @unique
  refCode   String?  // affiliate username who referred
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Discount {
  id         String    @id @default(cuid())
  author     User      @relation(fields: [authorId], references: [id])
  authorId   String
  post       Post?     @relation(fields: [postId], references: [id])
  postId     String?   // null = valid for all posts by this author
  code       String    @unique
  type       String    // "percent" | "fixed"
  value      Int       // percent (1-100) or IDR amount
  maxUses    Int?      // null = unlimited
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
}

model Follow {
  id          String   @id @default(cuid())
  follower    User     @relation("follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  followerId  String
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Like {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model PostView {
  id       String   @id @default(cuid())
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId   String
  deviceId String
  viewedAt DateTime @default(now())

  @@unique([postId, deviceId])
}

model SavedPost {
  id      String   @id @default(cuid())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId  String
  savedAt DateTime @default(now())

  @@unique([userId, postId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
